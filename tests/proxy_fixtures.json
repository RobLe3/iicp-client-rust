      "request": {"method": "POST", "path": "/v1/messages", "body": {"model": "iicp", "max_tokens": 64, "stream": true, "messages": [{"role": "user", "content": "Hi"}]}},
      "mock": {"kind": "iicp_response", "value": {"status": "success", "result": {"choices": [{"message": {"role": "assistant", "content": "Hi there"}}], "usage": {}}}},
      "expect": {"status": 200, "content_type": "text/event-stream", "sse_event_types": ["message_start", "content_block_start", "content_block_delta", "content_block_stop", "message_delta", "message_stop"]}
