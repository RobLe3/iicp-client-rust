      "mock": {"kind": "iicp_response", "value": {"status": "success", "result": {"choices": [{"message": {"role": "assistant", "content": "Hi there"}}], "usage": {}}}},
      "expect": {"status": 200, "content_type": "application/json", "body_path": {"type": "message", "role": "assistant", "model": "iicp", "content.0.text": "Hi there"}}
